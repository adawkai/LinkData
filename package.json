{
  "name": "social-app",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "api:dev": "pnpm --filter @social/api start:dev",
    "api:prisma:generate": "pnpm --filter @social/api db:generate",
